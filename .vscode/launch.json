{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Dev (API + Vite)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "name": "Build",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "build"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "name": "Pack + Install Tarball Globally",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run pack:install",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Start (production)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["--yes", "bun", "src/server/bootstrapInstalled.ts"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "name": "Debug API (Bun only)",
      "type": "bun",
      "request": "launch",
      "program": "${workspaceFolder}/src/server/bootstrapDev.ts",
      "args": ["--dev", "--profile", "dev"],
      "cwd": "${workspaceFolder}",
      "stopOnEntry": false,
      "watchMode": true
    }
  ]
}

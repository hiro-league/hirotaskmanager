{
  "name": "taskmanager",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Local-only task board app (Bun + Hono + React)",
  "bin": {
    "hirotm": "./src/cli/index.ts"
  },
  "scripts": {
    "cli": "bun run src/cli/index.ts",
    "dev": "concurrently -k -n api,web -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npx --yes bun --watch src/server/index.ts",
    "dev:client": "npx --yes wait-on tcp:127.0.0.1:3001 && vite",
    "build": "vite build",
    "start": "NODE_ENV=production npx --yes bun src/server/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dnd-kit/abstract": "^0.3.2",
    "@dnd-kit/helpers": "^0.3.2",
    "@dnd-kit/react": "^0.3.2",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@fontsource/lora": "^5.2.8",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.95.2",
    "@uiw/react-md-editor": "^4.0.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^14.0.3",
    "hono": "^4.12.9",
    "lucide-react": "^1.7.0",
    "motion": "^12.38.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.2",
    "shadcn": "^4.1.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.2",
    "wait-on": "^8.0.5"
  },
  "packageManager": "bun@1.3.11"
}
